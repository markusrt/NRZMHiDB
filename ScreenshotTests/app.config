<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="entityFramework"
             type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
             requirePermission="false" />
  </configSections>
  <!-- The seeder (in this process) and the hosted app (IIS Express) both point at this
       dedicated, disposable LocalDB catalog so screenshots never touch dev data. -->
  <connectionStrings>
    <add name="DefaultConnection"
         connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=HaemophilusWeb_Screenshots;Integrated Security=True;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
      <parameters>
        <parameter value="v11.0" />
      </parameters>
    </defaultConnectionFactory>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
  <!-- Binding redirects are generated automatically (AutoGenerateBindingRedirects) so they match the
       test host's own dependency versions; manual redirects here would clash and break test discovery. -->
</configuration>
