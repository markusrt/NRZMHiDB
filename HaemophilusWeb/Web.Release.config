<?xml version="1.0"?>

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
    <!-- Add your personal Geoname.org account here as demo account is rate limited -->
    <add key="GeonamesAccount" value="demo"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />

    <!-- Secret token to access the registration page -->
    <add key="RegistrationToken" value="LetMeIn"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
  </appSettings>
  <system.web>
	<compilation xdt:Transform="RemoveAttributes(debug)" />
  </system.web>
</configuration>